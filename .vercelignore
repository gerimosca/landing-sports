# When this file exists, Vercel uses it INSTEAD of .gitignore.
# Keep in sync with .gitignore + add deploy-only exclusions.

# --- mirror of .gitignore ---
/node_modules
/.pnp
.pnp.js
/coverage
/.next/
/out/
/build
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env*.local
.env.test
.vercel
*.tsbuildinfo
next-env.d.ts
.setup.json
setup-report.md
setup-export.json
src/i18n/generated/
*.backup
*.backup.*
*.old
*backup*/
*.log
*.plan.md
*.wip.md

# --- deploy-only: exclude original source images ---
# We pre-generate responsive WebP variants via `npm run optimize:images`
# and only those are served to clients. The source JPG/PNG files stay in
# git as backups (so we can re-optimize) but don't need to ship to Vercel.
public/images/**/*.jpg
public/images/**/*.jpeg
public/images/**/*.png

# Diagnostic artifacts
low-res-images.csv
